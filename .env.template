# ═══════════════════════════════════════════════════════
#  SUPER OTONOM v7 — Environment Variables
#  Bu dosyayı .env olarak kaydet, .env.example'ı değiştirme!
# ═══════════════════════════════════════════════════════

# ─── GENEL ───────────────────────────────────────────
DRY_RUN=true          # true = gerçek emir gönderilmez
PAPER_MODE=true       # true = paper trading
LOG_LEVEL=INFO        # DEBUG / INFO / WARNING / ERROR

# ─── EXCHANGE ────────────────────────────────────────
DEFAULT_EXCHANGE=binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true

# ─── RİSK ────────────────────────────────────────────
MAX_POSITION_PCT=0.05
MAX_OPEN_POSITIONS=1
STOP_LOSS_PCT=0.015
TAKE_PROFIT_PCT=0.03
MAX_DAILY_LOSS_PCT=0.05
MAX_TOTAL_DRAWDOWN=0.20

# ─── METRİKS ─────────────────────────────────────────
METRICS_PORT=8000

# ─── ML SERVİS (opsiyonel) ───────────────────────────
ML_SERVICE_ENABLED=false
ML_SERVICE_URL=

# ─── GRAFANA ─────────────────────────────────────────
GRAFANA_PASSWORD=admin123
