# ═══════════════════════════════════════════════════════
#  SUPER OTONOM v7 — Environment Variables
#  Bu dosyayı .env olarak kaydet, .env.example'ı değiştirme!
# ═══════════════════════════════════════════════════════

# ─── GENEL ───────────────────────────────────────────
DRY_RUN=true          # false = borsaya imzalı istek (canlı emir yolu açık)
PAPER_MODE=true       # false = simülatör yerine ccxt create_order (LIVE)
LIVE_CONFIRM=         # canlı için: YES (bilinçli onay; yoksa bot çıkar)
LOG_LEVEL=INFO        # DEBUG / INFO / WARNING / ERROR
LOG_FORMAT=text       # text | json (Loki/ELK uyumlu satir log)

# ─── AIOHTTP / DNS (Windows ve kurumsal ag) ───────────
# ThreadedResolver kodda; proxy env: Windows'ta varsayilan kapali.
# SUPER_OTONOM_AIOHTTP_TRUST_ENV=0
# SUPER_OTONOM_AIOHTTP_TRUST_ENV=1   kurumsal HTTP(S)_PROXY gerekiyorsa
# SUPER_OTONOM_AIOHTTP_IPV4_ONLY=1   DNS/IPv6 sorununda dene
# SUPER_OTONOM_AIOHTTP_DEFAULT_RESOLVER=1  (nadiren) varsayilan resolver yolunu zorla

# ─── EXCHANGE ────────────────────────────────────────
DEFAULT_EXCHANGE=binance
# Gerçek zamanlı kline (varsayılan açık); kapatırsanız POLL_INTERVAL_SEC ile REST turu
WS_ENABLED=true
WS_MTF_REFRESH_SEC=300
POLL_INTERVAL_SEC=30
# API anahtarları .env'e yazmayın — Vault KV (secret/trading/<exchange>)
# Yerel seed (bir kez): python -m super_otonom.vault_seed
BINANCE_TESTNET=true
BYBIT_TESTNET=true

# ─── RİSK ────────────────────────────────────────────
MAX_POSITION_PCT=0.05
MAX_OPEN_POSITIONS=1
STOP_LOSS_PCT=0.015
TAKE_PROFIT_PCT=0.03
MAX_DAILY_LOSS_PCT=0.05
MAX_TOTAL_DRAWDOWN=0.20

# ─── METRİKS / ALARM ─────────────────────────────────
METRICS_PORT=8000
# Alertmanager (docker-compose): Prometheus uyarıları → Telegram köprüsü
# Varsayılan docker içi DNS adı; ALERTMANAGER_WEBHOOK_URL ile özelleştirin.
ALERTMANAGER_WEBHOOK_URL=http://alert_telegram:8081/alert
# Bot içi AlertManager doğrudan HTTP (Slack/Discord JSON). Boş bırakın: yanlışlıkla
# WEBHOOK_URL=alert_telegram kullanıldığında host üzerinde getaddrinfo gürültüsü oluşmasın.
# İsterseniz buraya Slack webhook URL yazın; docker içinden Alert köprüsü için TELEGRAM yolu Prometheus kullanın.
ALERT_WEBHOOK_URL=
# Circuit breaker / adaptive throttle özet konsol WARNING sıklığı (saniye)
# CB_CONSOLE_LOG_INTERVAL_SEC=120
# Telegram (@BotFather + chat id); veya data/local/telegram.env + scripts/setup_telegram_alerts.ps1
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── ML SERVİS (opsiyonel) ───────────────────────────
ML_SERVICE_ENABLED=false
ML_SERVICE_URL=

# ─── DOCKER COMPOSE (TimescaleDB, Grafana, bot → DB) ───
# docker-compose.yml içinde sabit parola yok. Yerel: değer üret → openssl rand -base64 18
POSTGRES_USER=superotonom
POSTGRES_PASSWORD=
POSTGRES_DB=trading
GRAFANA_PASSWORD=
TIMESCALE_HOST=timescaledb
TIMESCALE_JOURNAL_MIRROR=0
# Bot TimescaleBridge (Docker dışı çalıştırırken POSTGRES ile aynı tutun):
# TIMESCALE_USER=superotonom
# TIMESCALE_PASSWORD=

# ─── VAULT (üretim: yalnızca VAULT_ADDR + AppRole; API anahtarları KV'de) ───
VAULT_ADDR=http://vault:8200
# Host uzerinden vault_seed / main_loop: otomatik 127.0.0.1 fallback (veya VAULT_ADDR_HOST)
# Geliştirme (kısa ömürlü): VAULT_TOKEN=
VAULT_ROLE_ID=
VAULT_SECRET_ID=
VAULT_MOUNT=secret
VAULT_BASE_PATH=trading
# Canlıda otomatik true (DRY_RUN=false, PAPER_MODE=false); zorla: SECRETS_VAULT_ONLY=true
SECRETS_VAULT_ONLY=
SECRETS_VAULT_ONLY_AUTO=true
# Host sırası (Faz 3): önce scripts\vault_seed.cmd, sonra scripts\env_harden_secrets.cmd — ters sıra kullanma (docs/RUNBOOK.md).

# ─── REDIS / Go kline köprüsü (Faz 4) ─────────────────
# REDIS_URL=redis://localhost:6379/0
# STALE_DATA / ZAMAN_KAYMASI: super_otonom/data_freshness.py — TIMEFRAME ile uyumlu
# REDIS_KLINE_TIMEFRAME=5m
# REDIS_KLINE_TIMEFRAME_BUFFER_SEC=90
# REDIS_KLINE_MAX_AGE_MS=   (boşsa TF+buffer; Python okuma eşiği)
# REDIS_KLINE_TTL_SECONDS=900   (Go SET EX — yazım kesilince anahtar düşer; ~2× max yaş önerilir)
# REDIS_KLINE_KEY_SUFFIX=kline_5m
# Bozuk anahtarlar: Python REPL veya script ile RedisBridge.clear_stale_kline_keys()

# ─── Mutabakat / paper (Faz 5) ───────────────────────
# RECON_SIM_SKIP_SIGNED_FETCH=1   DRY_RUN+PAPER iken borsa bakiye cekme (apiKey gurultusu yok); log INFO/DEBUG
# RECON_FETCH_BALANCE_IN_SIM=1   imzali fetch_balance (anahtar + BINANCE_SIGN_REQUESTS_IN_DRY_RUN); SKIP ile birlikte kullanma
# RECON_AUTO_FAIL_SKIPPED_PENDING=true   SKIPPED recovery → iptal; bos pending dosyasi silinir
# Bot kapali: data/pending_orders.json gereksizse sil

# ---- Ag (compose) ----
# Varsayilan: Postgres/Vault/Grafana dis porta kapali. Yerel: docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d
# TLS: scripts/gen_internal_tls.ps1 sonra -f docker-compose.tls.yml
