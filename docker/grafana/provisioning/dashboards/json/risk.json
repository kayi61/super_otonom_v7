    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "VaR timeline — model × confidence overlay. Negatif = kayıp yönü.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "VaR (fraction)",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "mode": "none" }
          },
          "unit": "percentunit"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*aggregate.*" },
            "properties": [
              { "id": "custom.lineWidth", "value": 3 },
              { "id": "custom.fillOpacity", "value": 20 }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "expr": "bot_var_pct{conf=~\"$conf\", model=~\"$model\", scope=\"portfolio\"}", "legendFormat": "VaR {{conf}}% {{model}}" },
        { "expr": "bot_var_99_current", "legendFormat": "VaR 99% (kill-switch)" }
      ],
      "title": "1 — Total VaR Timeline",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
