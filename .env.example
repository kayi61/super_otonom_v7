# super_otonom — örnek ortam (değerleri kopyalayıp .env yapın; .env commitlenmez)
# Ayrıntı: docs/RUNBOOK.md

# ---- Güven (önce simülasyon) ----
DRY_RUN=true
PAPER_MODE=true
LIVE_CONFIRM=
# Canlı spot limit emirleri (gerçek borsa) — gerçek para riski:
#   DRY_RUN=false
#   PAPER_MODE=false
#   LIVE_CONFIRM=YES
#   API anahtarları Vault KV'de (SECRETS_VAULT_ONLY); .env'de BINANCE_* yok
# Binance'da DRY_RUN iken imzalı deneme: BINANCE_SIGN_REQUESTS_IN_DRY_RUN=1

# ---- BotEngine god class (audit 8) ----
# LOC manifest: data/bot_engine_topology_manifest.json
BOT_ENGINE_FILE_LINE_CEILING=1450
BOT_ENGINE_CLASS_LINE_CEILING=1100

# ---- Paket topolojisi / god package (audit 7) ----
# Düz super_otonom/*.py tavanı; manifest: data/package_topology_manifest.json
PACKAGE_FLAT_PROD_CEILING=120

# ---- Saat / clock skew (audit 6) ----
# Borsa offset: ccxt load_time_difference → bot_clock_skew_* ; Prometheus: docker/prometheus/alerts.yml
CLOCK_SKEW_WARN_MS=500
CLOCK_SKEW_CRIT_MS=2000

# ---- Ağ / döngü ----
DEFAULT_EXCHANGE=binance
# aiohttp (Windows DNS / proxy): kod ThreadedResolver kullanir; sorun cikarsa:
# SUPER_OTONOM_AIOHTTP_TRUST_ENV=0   Windows varsayilan; kurumsal proxy icin 1
# SUPER_OTONOM_AIOHTTP_IPV4_ONLY=1  "Could not contact DNS servers" / IPv6 sapmasinda dene
POLL_INTERVAL_SEC=30
# WS_ENABLED=true (varsayılan): borsa WebSocket + mum kapanınca tick; REST yalnızca seed/MTF/ALT
WS_ENABLED=true
WS_MTF_REFRESH_SEC=300
LOG_LEVEL=INFO
INITIAL_CAPITAL=1000

# ---- OMEGA / kalite ----
SIGNAL_QUALITY_MIN=50
ML_SERVICE_ENABLED=false
ML_SERVICE_URL=
ML_SERVICE_TIMEOUT=2.0

# ---- Risk (örnek) ----
MAX_OPEN_POSITIONS=1
# MAX_POSITION_COUNT=3
STOP_LOSS_PCT=0.02
MAX_POSITION_PCT=0.05
TAKE_PROFIT_PCT=0.03

# ---- Borsa ----
# Kamu OHLCV için ana ağ: testnet bağlantı sorunu yaşanırsa false deneyin.
BINANCE_TESTNET=false
# ---- Vault (üretim: AppRole; API anahtarları commitlenmez) ----
VAULT_ADDR=http://vault:8200
VAULT_ROLE_ID=
VAULT_SECRET_ID=
SECRETS_VAULT_ONLY=
# Host sırası (Faz 3): scripts\vault_seed.cmd → scripts\env_harden_secrets.cmd (docs/RUNBOOK.md)
# Faz 5 (paper gürültüsü): RECON_SIM_SKIP_SIGNED_FETCH=1 — borsa bakiye cekmez; read-only icin RECON_FETCH_BALANCE_IN_SIM=1
# RECON_AUTO_FAIL_SKIPPED_PENDING=true — SKIPPED recovery temizligi; bot kapali: data/pending_orders.json gereksizse sil

# ---- Docker Compose (TimescaleDB + Grafana; compose’ta sabit şifre yok) ----
POSTGRES_USER=superotonom
POSTGRES_PASSWORD=
POSTGRES_DB=trading
GRAFANA_PASSWORD=

TIMESCALE_HOST=timescaledb
TIMESCALE_JOURNAL_MIRROR=0

# ---- Borsa ----
BINANCE_TESTNET=false

# ---- Güvenlik & Simülasyon ----
DRY_RUN=true
PAPER_MODE=true
SIGNAL_QUALITY_MIN=50
